{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:criteria-catalog:1.0.0",
  "title": "Accessibility Criteria Metadata Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "catalog_status", "verified_at", "copyright_boundary", "sources", "catalogs"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "catalog_status": {"const": "metadata_complete"},
    "verified_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "copyright_boundary": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "url", "role", "source_sha256"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "url": {"type": "string", "pattern": "^https://"},
          "role": {"type": "string", "minLength": 1},
          "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "catalogs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["web_modern", "jis_x_8341_3_2016", "jp_wcag_2_2_additional"],
      "properties": {
        "web_modern": {"type": "array", "minItems": 55, "maxItems": 55, "items": {"$ref": "#/$defs/criterion"}},
        "jis_x_8341_3_2016": {"type": "array", "minItems": 38, "maxItems": 38, "items": {"$ref": "#/$defs/criterion"}},
        "jp_wcag_2_2_additional": {"type": "array", "minItems": 18, "maxItems": 18, "items": {"$ref": "#/$defs/criterion"}}
      }
    }
  },
  "$defs": {
    "criterion": {
      "type": "object",
      "required": [
        "id", "success_criterion", "level", "evidence_hints", "method_key", "official_method_sources",
        "applicability_instruction", "expectation_instruction", "method_status",
        "method_requirement", "automation_role", "normative_text_included"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "success_criterion": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        "level": {"enum": ["A", "AA"]},
        "title_en": {"type": "string", "minLength": 1},
        "title_ja": {"type": "string", "minLength": 1},
        "normative_url": {"type": "string", "pattern": "^https://"},
        "checklist_source_url": {"type": "string", "pattern": "^https://"},
        "profile_source_url": {"type": "string", "pattern": "^https://"},
        "evidence_hints": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "method_key": {"type": "string", "minLength": 1},
        "official_method_sources": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^https://"}},
        "applicability_instruction": {"type": "string", "minLength": 1},
        "expectation_instruction": {"type": "string", "minLength": 1},
        "method_status": {"const": "profile_review_scaffold"},
        "method_requirement": {"const": "manual_or_hybrid"},
        "automation_role": {"const": "supporting_only"},
        "normative_text_included": {"const": false}
      }
    }
  }
}
