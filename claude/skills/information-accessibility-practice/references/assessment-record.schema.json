{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:assessment-record:1.0.0",
  "title": "Information Accessibility Assessment Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assessment"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "profile",
        "scope",
        "environment",
        "results",
        "participation_coverage",
        "evidence_level",
        "assurance",
        "claim",
        "evaluator",
        "evaluated_at",
        "limitations"
      ],
      "properties": {
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version_or_commit", "urls_or_files"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "version_or_commit": {"type": "string", "minLength": 1},
            "urls_or_files": {"type": "array", "items": {"type": "string"}}
          }
        },
        "profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "registry_version"],
          "properties": {
            "id": {"type": "string", "minLength": 1},
            "registry_version": {"const": "1.0.0"}
          }
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["included", "excluded", "complete_processes", "third_party_content", "full_pages_reviewed"],
          "properties": {
            "included": {"type": "array", "items": {"type": "string"}},
            "excluded": {"type": "array", "items": {"type": "string"}},
            "complete_processes": {"type": "array", "items": {"type": "string"}},
            "third_party_content": {"type": "array", "items": {"type": "string"}},
            "full_pages_reviewed": {"type": "boolean"}
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": false,
          "required": ["os", "browsers", "assistive_technologies", "input_modes"],
          "properties": {
            "os": {"type": "array", "items": {"type": "string"}},
            "browsers": {"type": "array", "items": {"type": "string"}},
            "assistive_technologies": {"type": "array", "items": {"type": "string"}},
            "input_modes": {"type": "array", "items": {"type": "string"}}
          }
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["requirement_id", "requirement_kind", "requirement_source", "mapping_status", "outcome", "method_kind", "method", "evidence", "notes"],
            "properties": {
              "requirement_id": {"type": "string", "minLength": 1},
              "requirement_kind": {"enum": ["profile_requirement", "screening_check"]},
              "requirement_source": {"type": "string"},
              "mapping_status": {"enum": ["unverified", "human_verified"]},
              "outcome": {"enum": ["pass", "fail", "not_applicable", "not_tested", "cant_tell"]},
              "method_kind": {"enum": ["manual", "automated", "hybrid"]},
              "method_ref": {"type": "string", "minLength": 1},
              "method": {"type": "string", "minLength": 1},
              "evidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["type", "location", "observation", "captured_at"],
                  "properties": {
                    "type": {"enum": ["manual_observation", "automated_scan", "browser_inspection", "keyboard_test", "assistive_technology_test", "document_structure_inspection", "screenshot", "log", "report", "other"]},
                    "location": {"type": "string", "minLength": 1},
                    "observation": {"type": "string", "minLength": 1},
                    "captured_at": {"type": "string", "format": "date-time"}
                  }
                }
              },
              "notes": {"type": "string"}
            }
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "priority", "requirement_ids", "location", "affected_users", "observation", "remediation", "verification"],
            "properties": {
              "id": {"type": "string", "minLength": 1},
              "priority": {"enum": ["P0", "P1", "P2"]},
              "requirement_ids": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "location": {"type": "string", "minLength": 1},
              "affected_users": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "observation": {"type": "string", "minLength": 1},
              "remediation": {"type": "string", "minLength": 1},
              "verification": {"type": "string", "minLength": 1}
            }
          }
        },
        "participation_coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["find", "receive", "understand", "participate", "continue"],
          "properties": {
            "find": {"enum": ["pass", "fail", "not_applicable", "not_tested", "cant_tell"]},
            "receive": {"enum": ["pass", "fail", "not_applicable", "not_tested", "cant_tell"]},
            "understand": {"enum": ["pass", "fail", "not_applicable", "not_tested", "cant_tell"]},
            "participate": {"enum": ["pass", "fail", "not_applicable", "not_tested", "cant_tell"]},
            "continue": {"enum": ["pass", "fail", "not_applicable", "not_tested", "cant_tell"]}
          }
        },
        "evidence_level": {"enum": ["E0", "E1", "E2", "E3", "E4", "E5"]},
        "assurance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["independent_audit", "legal_or_procurement_dossier"],
          "properties": {
            "independent_audit": {
              "type": "object",
              "additionalProperties": false,
              "required": ["performed", "evaluator_independent", "scope_method", "report_location"],
              "properties": {
                "performed": {"type": "boolean"},
                "evaluator_independent": {"type": "boolean"},
                "scope_method": {"type": "string"},
                "report_location": {"type": "string"}
              }
            },
            "legal_or_procurement_dossier": {
              "type": "object",
              "additionalProperties": false,
              "required": ["prepared", "responsible_owner", "artifacts"],
              "properties": {
                "prepared": {"type": "boolean"},
                "responsible_owner": {"type": "string"},
                "artifacts": {"type": "array", "items": {"type": "string", "minLength": 1}}
              }
            }
          }
        },
        "claim": {
          "type": "object",
          "additionalProperties": false,
          "required": ["requested_tier", "proposed_wording"],
          "properties": {
            "requested_tier": {"enum": ["reference_only", "screened", "evaluated_subset", "evaluated_complete", "conformance_candidate", "human_signoff_required"]},
            "proposed_wording": {"type": "string"}
          }
        },
        "evaluator": {"type": "string", "minLength": 1},
        "evaluated_at": {"type": "string", "format": "date"},
        "limitations": {"type": "array", "items": {"type": "string"}},
        "next_review_at": {"type": ["string", "null"], "format": "date"}
      }
    }
  }
}
