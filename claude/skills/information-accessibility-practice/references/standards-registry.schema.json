{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:standards-registry:1.0.0",
  "title": "Information Accessibility Standards Registry",
  "type": "object",
  "required": [
    "schema_version",
    "last_verified_at",
    "outcomes",
    "claim_tiers",
    "claim_templates",
    "evidence_levels",
    "global_prohibited_claims",
    "profiles",
    "planned_profiles"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "last_verified_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "claim_tiers": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "claim_templates": {
      "type": "object"
    },
    "evidence_levels": {
      "type": "object"
    },
    "global_prohibited_claims": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/profile"
      }
    },
    "planned_profiles": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": [
        "id",
        "assessment_configuration"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "assessment_configuration": {
          "$ref": "#/$defs/assessment_configuration"
        }
      }
    },
    "assessment_configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active"
      ],
      "properties": {
        "active": {
          "type": "boolean"
        },
        "requires_web_interaction_evidence": {
          "type": "boolean"
        },
        "catalog_keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "label",
              "requirement_id_prefixes"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1,
                "pattern": "^(?!(?:__proto__|prototype|constructor)$)[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "requirement_id_prefixes": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "active": {
                "const": true
              }
            },
            "required": [
              "active"
            ]
          },
          "then": {
            "required": [
              "catalog_keys",
              "groups",
              "requires_web_interaction_evidence"
            ]
          }
        }
      ]
    }
  }
}
