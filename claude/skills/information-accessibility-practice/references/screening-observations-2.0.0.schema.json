{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:screening-observations:2.0.0",
  "title": "E0 and E1 Screening Observations With Report Judgements",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "observations"],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirement_id", "evidence_level", "method", "location", "observation", "captured_at", "profile_requirement_id", "report_outcome", "applicability", "report_rationale"],
        "properties": {
          "requirement_id": { "type": "string", "pattern": "^SCREEN-[A-Z0-9]+(?:-[A-Z0-9]+)*$" },
          "evidence_level": { "enum": ["E0", "E1"] },
          "method": { "type": "string", "minLength": 1 },
          "location": { "type": "string", "minLength": 1 },
          "observation": { "type": "string", "minLength": 1 },
          "captured_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
          "profile_requirement_id": { "type": ["string", "null"], "pattern": "^(?:WCAG-2\\.2-SC-[0-9]+(?:\\.[0-9]+){2}|JIS-X-8341-3-2016-SC-[0-9]+(?:\\.[0-9]+){2})$" },
          "report_outcome": { "enum": ["pass", "fail", "not_tested", "cant_tell", null] },
          "applicability": { "enum": ["applicable", "not_applicable", "undetermined"] },
          "report_rationale": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": { "properties": { "profile_requirement_id": { "type": "null" } }, "required": ["profile_requirement_id"] },
            "then": {
              "properties": {
                "report_outcome": { "const": null },
                "applicability": { "const": "undetermined" }
              }
            }
          },
          {
            "if": { "properties": { "applicability": { "const": "not_applicable" } }, "required": ["applicability"] },
            "then": { "properties": { "report_outcome": { "const": null } } }
          },
          {
            "if": { "properties": { "report_outcome": { "enum": ["pass", "fail"] } }, "required": ["report_outcome"] },
            "then": { "properties": { "applicability": { "const": "applicable" } } }
          },
          {
            "if": {
              "properties": {
                "profile_requirement_id": { "type": "string" },
                "applicability": { "const": "undetermined" }
              },
              "required": ["profile_requirement_id", "applicability"]
            },
            "then": { "properties": { "report_outcome": { "enum": ["not_tested", "cant_tell"] } } }
          },
          {
            "if": {
              "properties": {
                "profile_requirement_id": { "type": "string" },
                "applicability": { "const": "applicable" }
              },
              "required": ["profile_requirement_id", "applicability"]
            },
            "then": { "properties": { "report_outcome": { "enum": ["pass", "fail", "not_tested", "cant_tell"] } } }
          }
        ]
      }
    }
  }
}
