{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:screen-reader-ui-checks:1.0.0",
  "title": "Screen-reader UI Supporting Checks",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "verified_at", "status", "claim_effect", "sources", "invariant", "patterns"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "verified_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "status": {"const": "screening_checks"},
    "claim_effect": {"const": "supporting_only"},
    "sources": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string", "pattern": "^https://www\\.w3\\.org/"}},
    "invariant": {"type": "string", "minLength": 1},
    "patterns": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/pattern"}
    }
  },
  "$defs": {
    "non_empty_strings": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "expectation", "code_inspection", "runtime_verification", "evidence_types", "cant_tell_when", "human_review_required"],
      "properties": {
        "id": {"type": "string", "pattern": "^SCREEN-SR-[A-Z0-9-]+$"},
        "title": {"type": "string", "minLength": 1},
        "expectation": {"type": "string", "minLength": 1},
        "code_inspection": {"$ref": "#/$defs/non_empty_strings"},
        "runtime_verification": {"$ref": "#/$defs/non_empty_strings"},
        "evidence_types": {"$ref": "#/$defs/non_empty_strings"},
        "cant_tell_when": {"$ref": "#/$defs/non_empty_strings"},
        "human_review_required": {"const": true}
      }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "applicability", "source_urls", "checks"],
      "properties": {
        "id": {"enum": ["modal-dialog", "disclosure", "menu-button", "fragmented-text"]},
        "title": {"type": "string", "minLength": 1},
        "applicability": {"type": "string", "minLength": 1},
        "source_urls": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^https://www\\.w3\\.org/"}},
        "checks": {"type": "array", "minItems": 3, "items": {"$ref": "#/$defs/check"}}
      }
    }
  }
}
