{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:screening-observations:3.0.0",
  "title": "E0 and E1 Screening Observations With Signal Provenance and Human Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "observations"],
  "properties": {
    "schema_version": { "const": "3.0.0" },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirement_id", "evidence_level", "signal_class", "human_review_required", "method", "location", "observation", "captured_at", "evidence_provenance", "profile_requirement_id", "report_outcome", "applicability", "report_rationale"],
        "properties": {
          "requirement_id": { "type": "string", "pattern": "^SCREEN-[A-Z0-9]+(?:-[A-Z0-9]+)*$" },
          "evidence_level": { "enum": ["E0", "E1"] },
          "signal_class": { "enum": ["candidate_issue", "no_automated_signal", "inconclusive"] },
          "human_review_required": { "const": true },
          "method": { "type": "string", "minLength": 1 },
          "location": { "type": "string", "minLength": 1 },
          "observation": { "type": "string", "minLength": 1 },
          "captured_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
          "evidence_provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": ["collection_method", "tool_name", "tool_version", "rule_id", "target_dom", "viewport"],
            "properties": {
              "collection_method": { "enum": ["automated_tool", "static_inspection", "interactive_inspection"] },
              "tool_name": { "type": ["string", "null"], "minLength": 1 },
              "tool_version": { "type": ["string", "null"], "minLength": 1 },
              "rule_id": { "type": ["string", "null"], "minLength": 1 },
              "target_dom": { "type": ["string", "null"], "minLength": 1 },
              "viewport": {
                "type": ["object", "null"],
                "additionalProperties": false,
                "required": ["width_css_px", "height_css_px", "zoom_percent"],
                "properties": {
                  "width_css_px": { "type": "integer", "minimum": 1 },
                  "height_css_px": { "type": "integer", "minimum": 1 },
                  "zoom_percent": { "type": "integer", "minimum": 1 }
                }
              }
            },
            "allOf": [
              {
                "if": { "properties": { "collection_method": { "const": "automated_tool" } }, "required": ["collection_method"] },
                "then": {
                  "properties": {
                    "tool_name": { "type": "string", "minLength": 1 },
                    "tool_version": { "type": "string", "minLength": 1 },
                    "rule_id": { "type": "string", "minLength": 1 }
                  }
                }
              }
            ]
          },
          "profile_requirement_id": { "type": ["string", "null"], "pattern": "^(?:WCAG-2\\.2-SC-[0-9]+(?:\\.[0-9]+){2}|JIS-X-8341-3-2016-SC-[0-9]+(?:\\.[0-9]+){2})$" },
          "report_outcome": { "enum": ["not_tested", "cant_tell", null] },
          "applicability": { "enum": ["applicable", "not_applicable", "undetermined"] },
          "report_rationale": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": { "properties": { "profile_requirement_id": { "type": "null" } }, "required": ["profile_requirement_id"] },
            "then": { "properties": { "report_outcome": { "const": null }, "applicability": { "const": "undetermined" } } }
          },
          {
            "if": { "properties": { "applicability": { "const": "not_applicable" } }, "required": ["applicability"] },
            "then": { "properties": { "report_outcome": { "const": null } } }
          },
          {
            "if": { "properties": { "signal_class": { "enum": ["no_automated_signal", "inconclusive"] } }, "required": ["signal_class"] },
            "then": { "properties": { "report_outcome": { "enum": ["not_tested", "cant_tell", null] } } }
          },
          {
            "if": { "properties": { "profile_requirement_id": { "type": "string" }, "applicability": { "const": "undetermined" } }, "required": ["profile_requirement_id", "applicability"] },
            "then": { "properties": { "report_outcome": { "enum": ["not_tested", "cant_tell"] } } }
          },
          {
            "if": { "properties": { "profile_requirement_id": { "type": "string" }, "applicability": { "const": "applicable" } }, "required": ["profile_requirement_id", "applicability"] },
            "then": { "properties": { "report_outcome": { "enum": ["not_tested", "cant_tell"] } } }
          }
        ]
      }
    }
  }
}
