{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:fix-authorization:2.0.0",
  "title": "Declared Fix Authorization",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "authorization_id", "run_id", "authorizer_role", "authorizer_kind", "approved_by", "identity_authenticated", "declaration", "approved_at", "source_root", "allowed_paths", "allowed_operations", "change_bindings", "verification_commands", "remediation_artifact"],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "authorization_id": { "type": "string", "pattern": "^AUTH-[0-9]{8}-[A-Z0-9]{8}$" },
    "run_id": { "$ref": "#/$defs/run_id" },
    "authorizer_role": { "const": "declared_authorizer" },
    "authorizer_kind": { "const": "external_requester" },
    "approved_by": { "type": "string", "minLength": 1 },
    "identity_authenticated": { "const": false },
    "declaration": { "type": "string", "minLength": 1 },
    "approved_at": { "$ref": "#/$defs/timestamp" },
    "source_root": { "$ref": "#/$defs/absolute_path" },
    "allowed_paths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/relative_path" } },
    "allowed_operations": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["create", "modify", "delete"] } },
    "change_bindings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/change_binding" }
    },
    "verification_commands": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command_id", "executable", "args", "cwd"],
        "properties": {
          "command_id": { "$ref": "#/$defs/command_id" },
          "executable": { "type": "string", "pattern": "^(?![A-Za-z]:[\\\\/])(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))[A-Za-z0-9._@+-]+(?:[\\\\/][A-Za-z0-9._@+-]+)*$" },
          "args": { "type": "array", "items": { "type": "string" } },
          "cwd": { "$ref": "#/$defs/relative_path" }
        }
      }
    },
    "remediation_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "sha256"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/artifact_id" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  },
  "$defs": {
    "run_id": { "type": "string", "pattern": "^RUN-[0-9]{8}T[0-9]{6}Z-[A-Z0-9]{8}$" },
    "artifact_id": { "type": "string", "pattern": "^ART-[A-Z0-9][A-Z0-9-]{2,63}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "change_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "operation", "expected_before_sha256", "expected_after_sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/relative_path" },
        "operation": { "enum": ["create", "modify", "delete"] },
        "expected_before_sha256": {},
        "expected_after_sha256": {}
      },
      "allOf": [
        {
          "if": { "properties": { "operation": { "const": "create" } }, "required": ["operation"] },
          "then": {
            "properties": {
              "expected_before_sha256": { "type": "null" },
              "expected_after_sha256": { "$ref": "#/$defs/sha256" }
            }
          }
        },
        {
          "if": { "properties": { "operation": { "const": "modify" } }, "required": ["operation"] },
          "then": {
            "properties": {
              "expected_before_sha256": { "$ref": "#/$defs/sha256" },
              "expected_after_sha256": { "$ref": "#/$defs/sha256" }
            }
          }
        },
        {
          "if": { "properties": { "operation": { "const": "delete" } }, "required": ["operation"] },
          "then": {
            "properties": {
              "expected_before_sha256": { "$ref": "#/$defs/sha256" },
              "expected_after_sha256": { "type": "null" }
            }
          }
        }
      ]
    },
    "command_id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]{2,63}$" },
    "timestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "absolute_path": { "type": "string", "minLength": 1, "pattern": "^(?:[A-Za-z]:[\\\\/]|/|\\\\\\\\[^\\\\/\\u0000-\\u001F]+[\\\\/][^\\\\/\\u0000-\\u001F]+)[^\\u0000-\\u001F]*$" },
    "relative_path": { "type": "string", "pattern": "^(?![A-Za-z][A-Za-z0-9+.-]*:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))[^\\u0000-\\u001F]+$" }
  }
}
