{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:audit-run:4.0.0",
  "title": "Immutable Information Accessibility Audit Run",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "supersedes_run_id", "status", "target", "profile", "scope", "environment", "permissions", "resource_versions", "artifact_root", "artifacts", "history", "limitations"],
  "properties": {
    "schema_version": { "const": "4.0.0" },
    "run_id": { "$ref": "#/$defs/run_id" },
    "supersedes_run_id": { "type": ["string", "null"], "pattern": "^RUN-[0-9]{8}T[0-9]{6}Z-[A-Z0-9]{8}$" },
    "status": { "$ref": "#/$defs/status" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version_or_commit", "urls_or_files"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version_or_commit": { "type": "string", "minLength": 1 },
        "urls_or_files": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "registry_version"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "registry_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["included", "excluded", "complete_processes", "third_party_content", "full_pages_reviewed"],
      "properties": {
        "included": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "excluded": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "complete_processes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "third_party_content": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "full_pages_reviewed": { "type": "boolean" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "browsers", "assistive_technologies", "input_modes"],
      "properties": {
        "os": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "browsers": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "assistive_technologies": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "input_modes": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "interaction", "source_write", "command_execution", "allowed_actions", "forbidden_actions"],
      "properties": {
        "network": { "enum": ["denied", "allowlisted"] },
        "interaction": { "enum": ["read_only", "human_supervised"] },
        "source_write": { "enum": ["denied", "authorized_only"] },
        "command_execution": { "enum": ["denied", "authorized_verification_only"] },
        "allowed_actions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["execute_authorized_verification_commands", "human_supervised_interaction", "inspect_without_mutation", "read_allowlisted_resources", "write_authorized_files"] } },
        "forbidden_actions": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["execute_commands", "execute_unapproved_commands", "network_access", "network_outside_allowlist", "write_target"] } }
      },
      "allOf": [
        {
          "if": { "properties": { "network": { "const": "denied" }, "interaction": { "const": "read_only" }, "source_write": { "const": "denied" } }, "required": ["network", "interaction", "source_write"] },
          "then": { "properties": { "command_execution": { "const": "denied" }, "allowed_actions": { "const": ["inspect_without_mutation"] }, "forbidden_actions": { "const": ["execute_commands", "network_access", "write_target"] } } }
        },
        {
          "if": { "properties": { "network": { "const": "allowlisted" }, "interaction": { "const": "read_only" }, "source_write": { "const": "denied" } }, "required": ["network", "interaction", "source_write"] },
          "then": { "properties": { "command_execution": { "const": "denied" }, "allowed_actions": { "const": ["inspect_without_mutation", "read_allowlisted_resources"] }, "forbidden_actions": { "const": ["execute_commands", "network_outside_allowlist", "write_target"] } } }
        },
        {
          "if": { "properties": { "network": { "const": "denied" }, "interaction": { "const": "human_supervised" }, "source_write": { "const": "denied" } }, "required": ["network", "interaction", "source_write"] },
          "then": { "properties": { "command_execution": { "const": "denied" }, "allowed_actions": { "const": ["human_supervised_interaction", "inspect_without_mutation"] }, "forbidden_actions": { "const": ["execute_commands", "network_access", "write_target"] } } }
        },
        {
          "if": { "properties": { "network": { "const": "allowlisted" }, "interaction": { "const": "human_supervised" }, "source_write": { "const": "denied" } }, "required": ["network", "interaction", "source_write"] },
          "then": { "properties": { "command_execution": { "const": "denied" }, "allowed_actions": { "const": ["human_supervised_interaction", "inspect_without_mutation", "read_allowlisted_resources"] }, "forbidden_actions": { "const": ["execute_commands", "network_outside_allowlist", "write_target"] } } }
        },
        {
          "if": { "properties": { "network": { "const": "denied" }, "interaction": { "const": "read_only" }, "source_write": { "const": "authorized_only" } }, "required": ["network", "interaction", "source_write"] },
          "then": { "properties": { "command_execution": { "const": "authorized_verification_only" }, "allowed_actions": { "const": ["execute_authorized_verification_commands", "inspect_without_mutation", "write_authorized_files"] }, "forbidden_actions": { "const": ["execute_unapproved_commands", "network_access"] } } }
        },
        {
          "if": { "properties": { "network": { "const": "allowlisted" }, "interaction": { "const": "read_only" }, "source_write": { "const": "authorized_only" } }, "required": ["network", "interaction", "source_write"] },
          "then": { "properties": { "command_execution": { "const": "authorized_verification_only" }, "allowed_actions": { "const": ["execute_authorized_verification_commands", "inspect_without_mutation", "read_allowlisted_resources", "write_authorized_files"] }, "forbidden_actions": { "const": ["execute_unapproved_commands", "network_outside_allowlist"] } } }
        },
        {
          "if": { "properties": { "network": { "const": "denied" }, "interaction": { "const": "human_supervised" }, "source_write": { "const": "authorized_only" } }, "required": ["network", "interaction", "source_write"] },
          "then": { "properties": { "command_execution": { "const": "authorized_verification_only" }, "allowed_actions": { "const": ["execute_authorized_verification_commands", "human_supervised_interaction", "inspect_without_mutation", "write_authorized_files"] }, "forbidden_actions": { "const": ["execute_unapproved_commands", "network_access"] } } }
        },
        {
          "if": { "properties": { "network": { "const": "allowlisted" }, "interaction": { "const": "human_supervised" }, "source_write": { "const": "authorized_only" } }, "required": ["network", "interaction", "source_write"] },
          "then": { "properties": { "command_execution": { "const": "authorized_verification_only" }, "allowed_actions": { "const": ["execute_authorized_verification_commands", "human_supervised_interaction", "inspect_without_mutation", "read_allowlisted_resources", "write_authorized_files"] }, "forbidden_actions": { "const": ["execute_unapproved_commands", "network_outside_allowlist"] } } }
        }
      ]
    },
    "resource_versions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["standards_registry_version", "orchestration_registry_version", "orchestration_registry_sha256", "criteria_catalog_sha256", "criterion_procedures_sha256", "audit_methods_sha256"],
      "properties": {
        "standards_registry_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "orchestration_registry_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "orchestration_registry_sha256": { "$ref": "#/$defs/sha256" },
        "criteria_catalog_sha256": { "$ref": "#/$defs/sha256" },
        "criterion_procedures_sha256": { "$ref": "#/$defs/sha256" },
        "audit_methods_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "artifact_root": { "$ref": "#/$defs/relative_path" },
    "artifacts": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/artifact" } },
    "history": { "type": "array", "items": { "$ref": "#/$defs/history_entry" } },
    "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "run_id": { "type": "string", "pattern": "^RUN-[0-9]{8}T[0-9]{6}Z-[A-Z0-9]{8}$" },
    "artifact_id": { "type": "string", "pattern": "^ART-[A-Z0-9][A-Z0-9-]{2,63}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "relative_path": { "type": "string", "pattern": "^(?![A-Za-z][A-Za-z0-9+.-]*:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))[^\\u0000-\\u001F]+$" },
    "status": { "enum": ["initialized", "screened", "human_queue_ready", "human_review_recorded", "remediation_ready", "fix_authorized", "retest_required"] },
    "role": { "enum": ["orchestrator", "e1_inspector", "human_queue_planner", "declared_external_human", "remediation_planner", "declared_authorizer", "authorized_fixer"] },
    "artifact_type": { "enum": ["screening-observations", "human-review-queue", "declared-human-review", "remediation-plan", "fix-authorization", "change-record"] },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "artifact_type", "path", "sha256", "producer_role", "created_at", "validation_status"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/artifact_id" },
        "artifact_type": { "$ref": "#/$defs/artifact_type" },
        "path": { "$ref": "#/$defs/relative_path" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "producer_role": { "$ref": "#/$defs/role" },
        "created_at": { "$ref": "#/$defs/timestamp" },
        "validation_status": { "enum": ["valid", "invalid"] }
      }
    },
    "history_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "at", "actor_role", "artifact_ids"],
      "properties": {
        "from": { "enum": ["initialized", "screened", "human_queue_ready", "human_review_recorded", "remediation_ready", "fix_authorized"] },
        "to": { "$ref": "#/$defs/status" },
        "at": { "$ref": "#/$defs/timestamp" },
        "actor_role": { "$ref": "#/$defs/role" },
        "artifact_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/artifact_id" } }
      },
      "allOf": [
        { "if": { "properties": { "from": { "const": "initialized" } }, "required": ["from"] }, "then": { "properties": { "to": { "const": "screened" } } } },
        { "if": { "properties": { "from": { "const": "screened" } }, "required": ["from"] }, "then": { "properties": { "to": { "const": "human_queue_ready" } } } },
        { "if": { "properties": { "from": { "const": "human_queue_ready" } }, "required": ["from"] }, "then": { "properties": { "to": { "enum": ["human_review_recorded", "remediation_ready"] } } } },
        { "if": { "properties": { "from": { "const": "human_review_recorded" } }, "required": ["from"] }, "then": { "properties": { "to": { "const": "remediation_ready" } } } },
        { "if": { "properties": { "from": { "const": "remediation_ready" } }, "required": ["from"] }, "then": { "properties": { "to": { "const": "fix_authorized" } } } },
        { "if": { "properties": { "from": { "const": "fix_authorized" } }, "required": ["from"] }, "then": { "properties": { "to": { "const": "retest_required" } } } }
      ]
    }
  }
}
