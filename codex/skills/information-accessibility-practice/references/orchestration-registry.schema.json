{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:orchestration-registry:4.0.0",
  "title": "Extensible Information Accessibility Audit Orchestration Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "roles", "artifact_types", "transitions"],
  "properties": {
    "$schema": { "const": "./orchestration-registry.schema.json" },
    "schema_version": { "const": "4.0.0" },
    "roles": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/role" }
    },
    "artifact_types": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/artifact_type_manifest" }
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/transition" }
    }
  },
  "$defs": {
    "role_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
    "agent_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,127}$" },
    "artifact_type": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "state": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" },
    "artifact_type_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "latest_schema_version", "schema_versions"],
      "properties": {
        "id": { "$ref": "#/$defs/artifact_type" },
        "latest_schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "schema_versions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["version", "schema_file", "mode"],
            "properties": {
              "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
              "schema_file": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*\\.schema\\.json$" },
              "schema_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "mode": { "enum": ["current", "read_only"] }
            },
            "allOf": [
              {
                "if": { "properties": { "mode": { "const": "current" } }, "required": ["mode"] },
                "then": { "required": ["schema_sha256"] }
              }
            ]
          }
        }
      }
    },
    "role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "agent_id", "producer_kind", "input_types", "output_type", "max_ai_evidence_level", "can_record_profile_outcome", "can_write_target", "install_by_default"],
      "properties": {
        "id": { "$ref": "#/$defs/role_id" },
        "agent_id": { "type": ["string", "null"], "pattern": "^[a-z][a-z0-9-]{2,127}$" },
        "producer_kind": { "enum": ["ai_agent", "external_human", "external_requester"] },
        "input_types": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/artifact_type" }
        },
        "output_type": { "$ref": "#/$defs/artifact_type" },
        "max_ai_evidence_level": { "enum": ["E0", "E1", null] },
        "can_record_profile_outcome": { "type": "boolean" },
        "can_write_target": { "type": "boolean" },
        "install_by_default": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "producer_kind": { "const": "ai_agent" } }, "required": ["producer_kind"] },
          "then": { "properties": { "agent_id": { "$ref": "#/$defs/agent_id" }, "max_ai_evidence_level": { "enum": ["E0", "E1"] }, "can_record_profile_outcome": { "const": false } } }
        },
        {
          "if": { "properties": { "can_record_profile_outcome": { "const": true } }, "required": ["can_record_profile_outcome"] },
          "then": { "properties": { "id": { "const": "declared_external_human" }, "producer_kind": { "const": "external_human" } } }
        },
        {
          "if": { "properties": { "can_write_target": { "const": true } }, "required": ["can_write_target"] },
          "then": { "properties": { "id": { "const": "authorized_fixer" }, "output_type": { "const": "change-record" }, "install_by_default": { "const": false } } }
        },
        {
          "if": { "properties": { "output_type": { "const": "fix-authorization" } }, "required": ["output_type"] },
          "then": { "properties": { "id": { "const": "declared_authorizer" }, "agent_id": { "const": null }, "producer_kind": { "const": "external_requester" }, "can_write_target": { "const": false }, "install_by_default": { "const": false } } }
        }
      ]
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "required_artifact_types"],
      "properties": {
        "from": { "$ref": "#/$defs/state" },
        "to": { "$ref": "#/$defs/state" },
        "required_artifact_types": {
          "type": "array",
          "minItems": 1,
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/artifact_type" }
        }
      }
    }
  }
}
