{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:common-web-failure-patterns:1.0.0",
  "title": "Tool-independent Common Web Screening Patterns",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema_version", "catalog_kind", "verified_at", "usage_rule", "patterns"],
  "properties": {
    "$schema": { "const": "./common-web-failure-patterns.schema.json" },
    "schema_version": { "const": "1.0.0" },
    "catalog_kind": { "const": "tool_independent_screening_patterns" },
    "verified_at": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "usage_rule": { "type": "string", "minLength": 1 },
    "patterns": {
      "type": "array",
      "minItems": 11,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "faq_section", "signal_class", "trigger", "observation", "affected_users", "human_check", "remediation", "retest", "candidate_requirement_ids", "mapping_status", "claim_boundary", "primary_sources"],
        "properties": {
          "id": { "type": "string", "pattern": "^SCREEN-WEB-[A-Z0-9]+(?:-[A-Z0-9]+)*$" },
          "title": { "type": "string", "minLength": 1 },
          "faq_section": { "type": "string", "pattern": "^[2-7]\\.[0-9]+$" },
          "signal_class": { "enum": ["candidate_issue", "no_automated_signal", "inconclusive"] },
          "trigger": { "type": "string", "minLength": 1 },
          "observation": { "type": "string", "minLength": 1 },
          "affected_users": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "human_check": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "remediation": { "type": "string", "minLength": 1 },
          "retest": { "type": "string", "minLength": 1 },
          "candidate_requirement_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^WCAG-2\\.2-SC-[0-9]+(?:\\.[0-9]+){2}$" }
          },
          "mapping_status": { "const": "requires_human_verification" },
          "claim_boundary": { "type": "string", "minLength": 1 },
          "primary_sources": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string", "pattern": "^https://" } }
        }
      }
    }
  }
}
