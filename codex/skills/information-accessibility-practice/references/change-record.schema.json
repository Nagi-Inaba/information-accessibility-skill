{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:change-record:2.0.0",
  "title": "Authorized Target Change Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "change_id", "run_id", "authorization_id", "authorization_artifact", "changed_files", "diff_sha256", "command_results", "lease", "next_status"],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "change_id": { "type": "string", "pattern": "^CHANGE-[0-9]{8}-[A-Z0-9]{8}$" },
    "run_id": { "$ref": "#/$defs/run_id" },
    "authorization_id": { "type": "string", "pattern": "^AUTH-[0-9]{8}-[A-Z0-9]{8}$" },
    "authorization_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "sha256"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/artifact_id" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "changed_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "operation", "before_sha256", "after_sha256", "description"],
        "properties": {
          "path": { "$ref": "#/$defs/relative_path" },
          "operation": { "enum": ["create", "modify", "delete"] },
          "before_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "after_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "description": { "type": "string", "minLength": 1 }
        },
        "allOf": [
          {
            "if": { "properties": { "operation": { "const": "create" } }, "required": ["operation"] },
            "then": { "properties": { "before_sha256": { "const": null }, "after_sha256": { "$ref": "#/$defs/sha256" } } }
          },
          {
            "if": { "properties": { "operation": { "const": "modify" } }, "required": ["operation"] },
            "then": { "properties": { "before_sha256": { "$ref": "#/$defs/sha256" }, "after_sha256": { "$ref": "#/$defs/sha256" } } }
          },
          {
            "if": { "properties": { "operation": { "const": "delete" } }, "required": ["operation"] },
            "then": { "properties": { "before_sha256": { "$ref": "#/$defs/sha256" }, "after_sha256": { "const": null } } }
          }
        ]
      }
    },
    "diff_sha256": { "$ref": "#/$defs/sha256" },
    "command_results": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command_id", "executable", "args", "cwd", "status", "exit_code", "signal", "stdout_sha256", "stderr_sha256", "started_at", "completed_at"],
        "properties": {
          "command_id": { "$ref": "#/$defs/command_id" },
          "executable": { "type": "string", "pattern": "^(?![A-Za-z]:[\\\\/])(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))[A-Za-z0-9._@+-]+(?:[\\\\/][A-Za-z0-9._@+-]+)*$" },
          "args": { "type": "array", "items": { "type": "string" } },
          "cwd": { "$ref": "#/$defs/relative_path" },
          "status": { "enum": ["exited", "signaled", "spawn_error"] },
          "exit_code": { "type": ["integer", "null"] },
          "signal": { "type": ["string", "null"], "minLength": 1 },
          "stdout_sha256": { "$ref": "#/$defs/sha256" },
          "stderr_sha256": { "$ref": "#/$defs/sha256" },
          "started_at": { "$ref": "#/$defs/timestamp" },
          "completed_at": { "$ref": "#/$defs/timestamp" }
        },
        "allOf": [
          {
            "if": { "properties": { "status": { "const": "exited" } }, "required": ["status"] },
            "then": { "properties": { "exit_code": { "type": "integer" }, "signal": { "const": null } } }
          },
          {
            "if": { "properties": { "status": { "const": "signaled" } }, "required": ["status"] },
            "then": { "properties": { "exit_code": { "const": null }, "signal": { "type": "string", "minLength": 1 } } }
          },
          {
            "if": { "properties": { "status": { "const": "spawn_error" } }, "required": ["status"] },
            "then": { "properties": { "exit_code": { "const": null }, "signal": { "const": null } } }
          }
        ]
      }
    },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lease_id", "source_root_sha256", "acquired_at", "expires_at", "recovery"],
      "properties": {
        "lease_id": { "$ref": "#/$defs/lease_id" },
        "source_root_sha256": { "$ref": "#/$defs/sha256" },
        "acquired_at": { "$ref": "#/$defs/timestamp" },
        "expires_at": { "$ref": "#/$defs/timestamp" },
        "recovery": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["previous_lease_id", "previous_run_id", "previous_lease_sha256", "recovered_at"],
          "properties": {
            "previous_lease_id": { "$ref": "#/$defs/lease_id" },
            "previous_run_id": { "$ref": "#/$defs/run_id" },
            "previous_lease_sha256": { "$ref": "#/$defs/sha256" },
            "recovered_at": { "$ref": "#/$defs/timestamp" }
          }
        }
      }
    },
    "next_status": { "const": "retest_required" }
  },
  "$defs": {
    "run_id": { "type": "string", "pattern": "^RUN-[0-9]{8}T[0-9]{6}Z-[A-Z0-9]{8}$" },
    "artifact_id": { "type": "string", "pattern": "^ART-[A-Z0-9][A-Z0-9-]{2,63}$" },
    "command_id": { "type": "string", "pattern": "^[A-Z][A-Z0-9_-]{2,63}$" },
    "lease_id": { "type": "string", "pattern": "^LEASE-[0-9]{8}-[A-Z0-9]{8}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "relative_path": { "type": "string", "pattern": "^(?![A-Za-z][A-Za-z0-9+.-]*:)(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))[^\\u0000-\\u001F]+$" }
  }
}
