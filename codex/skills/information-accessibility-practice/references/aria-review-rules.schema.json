{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:aria-review-rules:1.0.0",
  "title": "ARIA Supporting Review Rules",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "verified_at", "status", "claim_effect", "sources", "rules"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "verified_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "status": {"const": "review_checks"},
    "claim_effect": {"const": "supporting_only"},
    "sources": {"type": "array", "minItems": 2, "items": {"type": "string", "pattern": "^https://www\\.w3\\.org/TR/"}},
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "kind", "source_url", "applicability", "expectation", "method_kinds", "evidence_types", "human_review_required"],
        "properties": {
          "id": {"type": "string", "pattern": "^SCREEN-ARIA-[A-Z0-9-]+$"},
          "title": {"type": "string", "minLength": 1},
          "kind": {"enum": ["normative_review", "advisory_review"]},
          "source_url": {"type": "string", "pattern": "^https://www\\.w3\\.org/TR/"},
          "applicability": {"type": "string", "minLength": 1},
          "expectation": {"type": "string", "minLength": 1},
          "method_kinds": {"type": "array", "minItems": 1, "items": {"enum": ["automated", "manual", "hybrid"]}},
          "evidence_types": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "human_review_required": {"const": true}
        }
      }
    }
  }
}
