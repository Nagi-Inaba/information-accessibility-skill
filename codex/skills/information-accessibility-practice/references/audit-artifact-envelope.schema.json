{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:information-accessibility:audit-artifact-envelope:2.0.0",
  "title": "Extensible Information Accessibility Audit Artifact Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_id", "artifact_type", "run_id", "producer", "created_at", "inputs", "payload"],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "artifact_id": { "$ref": "#/$defs/artifact_id" },
    "artifact_type": { "$ref": "#/$defs/artifact_type" },
    "run_id": { "$ref": "#/$defs/run_id" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role_id", "producer_kind", "origin"],
      "properties": {
        "role_id": { "$ref": "#/$defs/role" },
        "producer_kind": { "enum": ["ai_agent", "external_human", "external_requester"] },
        "origin": { "type": "string", "minLength": 1 }
      }
    },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "inputs": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "run_id", "sha256"],
        "properties": {
          "artifact_id": { "$ref": "#/$defs/artifact_id" },
          "run_id": { "$ref": "#/$defs/run_id" },
          "sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "payload": { "type": "object" }
  },
  "$defs": {
    "run_id": { "type": "string", "pattern": "^RUN-[0-9]{8}T[0-9]{6}Z-[A-Z0-9]{8}$" },
    "artifact_id": { "type": "string", "pattern": "^ART-[A-Z0-9][A-Z0-9-]{2,63}$" },
    "artifact_type": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "role": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,63}$" }
  }
}
